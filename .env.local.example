# ============================================================
# Hands of Hope — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Email (for Supabase Auth)
NEXT_PUBLIC_ADMIN_EMAIL=admin@handsofhopewcen.org

# App URL
NEXT_PUBLIC_SITE_URL=https://handsofhopewcen.org

# Formspree (optional — forms post directly to Supabase now)
# NEXT_PUBLIC_FORMSPREE_SUPPORT=your-form-id
# NEXT_PUBLIC_FORMSPREE_VOLUNTEER=your-form-id
# NEXT_PUBLIC_FORMSPREE_PARTNER=your-form-id
# NEXT_PUBLIC_FORMSPREE_CONTACT=your-form-id
